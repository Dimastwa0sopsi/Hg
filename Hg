<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Russian RP - 3D Sandbox</title>
<style>
  body { margin: 0; overflow: hidden; font-family: Arial, sans-serif; }
  canvas { display: block; }
  #ui {
    position: absolute; top: 20px; left: 20px;
    color: white; text-shadow: 2px 2px 4px rgba(0,0,0,0.8);
    font-size: 18px; pointer-events: none;
  }
  #money { font-size: 24px; color: #4CAF50; font-weight: bold; }
  #speedometer {
    position: absolute; bottom: 30px; right: 30px;
    background: rgba(0,0,0,0.7); color: white;
    padding: 15px 25px; border-radius: 15px;
    font-size: 36px; font-weight: bold;
    border: 2px solid #4CAF50;
  }
  #hint {
    position: absolute; bottom: 30px; left: 50%;
    transform: translateX(-50%);
    background: rgba(0,0,0,0.8); color: #FFD700;
    padding: 10px 25px; border-radius: 25px;
    font-size: 14px; text-align: center;
  }
  #inventory {
    position: absolute; top: 20px; right: 20px;
    background: rgba(0,0,0,0.8); color: white;
    padding: 15px; border-radius: 10px;
    min-width: 150px; pointer-events: none;
  }
  .shop-panel {
    position: absolute; top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    background: rgba(20,20,20,0.95); color: white;
    padding: 25px; border-radius: 15px;
    border: 2px solid #FFD700; display: none;
    z-index: 100; min-width: 300px;
    pointer-events: all;
  }
  .shop-panel h3 { margin-top: 0; color: #FFD700; text-align: center; }
  .shop-btn {
    display: block; width: 100%; margin: 8px 0;
    padding: 12px; background: #333; color: white;
    border: 1px solid #555; border-radius: 8px;
    cursor: pointer; font-size: 14px; transition: 0.2s;
  }
  .shop-btn:hover { background: #4CAF50; }
  .close-btn {
    position: absolute; top: 10px; right: 15px;
    background: red; color: white; border: none;
    border-radius: 50%; width: 30px; height: 30px;
    cursor: pointer; font-weight: bold;
  }
</style>
</head>
<body>

<div id="ui">
  <div>💰 Баланс: <span id="money">50 000 ₽</span></div>
  <div id="car-name" style="color:#FFD700;">🚶 Пешком</div>
</div>

<div id="inventory">
  <strong>🎒 Инвентарь</strong>
  <div id="inv-list" style="margin-top:8px; font-size:13px;">Пусто</div>
</div>

<div id="speedometer">0 км/ч</div>

<div id="hint">
  🎮 WASD/Стрелки - движение | E - войти в машину | F - взаимодействие | Q - выйти из машины | Пробел - ручник
</div>

<!-- Панель магазина -->
<div id="shop-panel" class="shop-panel">
  <button class="close-btn" onclick="closeShop()">✕</button>
  <h3 id="shop-title">Магазин</h3>
  <div id="shop-content"></div>
</div>

<script type="importmap">
{
  "imports": {
    "three": "https://unpkg.com/three@0.160.0/build/three.module.js",
    "three/addons/": "https://unpkg.com/three@0.160.0/examples/jsm/"
  }
}
</script>

<script type="module">
import * as THREE from 'three';
import { OrbitControls } from 'three/addons/controls/OrbitControls.js';
import { CSS2DRenderer, CSS2DObject } from 'three/addons/renderers/CSS2DRenderer.js';

// ============ ОСНОВНЫЕ ПЕРЕМЕННЫЕ ============
let money = 50000;
let inventory = [];
let currentCar = null;
let isInCar = false;
let playerSpeed = 0.15;
let carSpeed = 0;
const maxCarSpeed = 1.2;
const carAcceleration = 0.04;
const carBrake = 0.06;
const carFriction = 0.02;
let handbrake = false;

// ============ СЦЕНА ============
const scene = new THREE.Scene();
scene.background = new THREE.Color(0x87CEEB);
scene.fog = new THREE.Fog(0x87CEEB, 100, 600);

const camera = new THREE.PerspectiveCamera(70, window.innerWidth / window.innerHeight, 1, 1000);
camera.position.set(30, 25, 30);

const renderer = new THREE.WebGLRenderer({ antialias: true });
renderer.setSize(window.innerWidth, window.innerHeight);
renderer.shadowMap.enabled = true;
renderer.shadowMap.type = THREE.PCFSoftShadowMap;
document.body.appendChild(renderer.domElement);

// CSS2D для меток
const labelRenderer = new CSS2DRenderer();
labelRenderer.setSize(window.innerWidth, window.innerHeight);
labelRenderer.domElement.style.position = 'absolute';
labelRenderer.domElement.style.top = '0px';
labelRenderer.domElement.style.pointerEvents = 'none';
document.body.appendChild(labelRenderer.domElement);

// Свет
const ambientLight = new THREE.AmbientLight(0x404060, 1.2);
scene.add(ambientLight);
const sunLight = new THREE.DirectionalLight(0xffffff, 2.5);
sunLight.position.set(100, 150, 50);
sunLight.castShadow = true;
sunLight.shadow.mapSize.width = 2048;
sunLight.shadow.mapSize.height = 2048;
sunLight.shadow.camera.near = 1;
sunLight.shadow.camera.far = 500;
sunLight.shadow.camera.left = -100;
sunLight.shadow.camera.right = 100;
sunLight.shadow.camera.top = 100;
sunLight.shadow.camera.bottom = -100;
scene.add(sunLight);

// ============ ИГРОК ============
const playerGeometry = new THREE.CapsuleGeometry(0.4, 1.2, 4, 8);
const playerMaterial = new THREE.MeshStandardMaterial({ color: 0x3366cc });
const player = new THREE.Mesh(playerGeometry, playerMaterial);
player.position.set(0, 1, 5);
player.castShadow = true;
scene.add(player);

// ============ МАШИНЫ (АВТОСАЛОН) ============
const cars = [];
const carModels = [
  { name: 'Lada Priora', color: 0x111111, price: 150000, pos: [-8, 0.5, 8] },
  { name: 'BMW M5', color: 0x1a1aff, price: 450000, pos: [-2, 0.5, 8] },
  { name: 'Mercedes G-Class', color: 0xffffff, price: 600000, pos: [4, 0.5, 8] },
  { name: 'Toyota Supra', color: 0xff4400, price: 350000, pos: [10, 0.5, 8] },
  { name: 'Lada Vesta', color: 0x880000, price: 120000, pos: [-8, 0.5, -8] },
  { name: 'VAZ 2107', color: 0xdddddd, price: 80000, pos: [-2, 0.5, -8] },
  { name: 'Porsche 911', color: 0xffff00, price: 750000, pos: [4, 0.5, -8] },
  { name: 'Lamborghini', color: 0xff6600, price: 1200000, pos: [10, 0.5, -8] },
];

function createCar(model) {
  const group = new THREE.Group();
  
  // Кузов
  const bodyGeo = new THREE.BoxGeometry(1.8, 0.6, 4.2);
  const bodyMat = new THREE.MeshStandardMaterial({ color: model.color, metalness: 0.6, roughness: 0.3 });
  const body = new THREE.Mesh(bodyGeo, bodyMat);
  body.position.y = 0.5;
  body.castShadow = true;
  group.add(body);
  
  // Кабина
  const cabinGeo = new THREE.BoxGeometry(1.4, 0.5, 1.8);
  const cabinMat = new THREE.MeshStandardMaterial({ color: 0x88ccff, metalness: 0.3, roughness: 0.1, opacity: 0.5, transparent: true });
  const cabin = new THREE.Mesh(cabinGeo, cabinMat);
  cabin.position.set(0, 0.95, -0.1);
  cabin.castShadow = true;
  group.add(cabin);
  
  // Колеса
  const wheelGeo = new THREE.CylinderGeometry(0.35, 0.35, 0.3, 16);
  const wheelMat = new THREE.MeshStandardMaterial({ color: 0x111111, roughness: 0.8 });
  const wheelPositions = [[-0.95, 0.2, 1.3], [0.95, 0.2, 1.3], [-0.95, 0.2, -1.3], [0.95, 0.2, -1.3]];
  wheelPositions.forEach(([x, y, z]) => {
    const wheel = new THREE.Mesh(wheelGeo, wheelMat);
    wheel.position.set(x, y, z);
    wheel.rotation.z = Math.PI / 2;
    wheel.castShadow = true;
    group.add(wheel);
  });
  
  // Фары
  const headlightGeo = new THREE.SphereGeometry(0.15, 8, 8);
  const headlightMat = new THREE.MeshStandardMaterial({ color: 0xffffcc, emissive: 0xffffcc, emissiveIntensity: 0.3 });
  [-0.5, 0.5].forEach(x => {
    const hl = new THREE.Mesh(headlightGeo, headlightMat);
    hl.position.set(x, 0.5, 2.1);
    group.add(hl);
  });
  
  group.position.set(model.pos[0], model.pos[1], model.pos[2]);
  group.userData = { 
    model: model,
    isCar: true,
    rotation: 0
  };
  
  return group;
}

carModels.forEach(model => {
  const car = createCar(model);
  scene.add(car);
  cars.push(car);
});

// ============ ДОРОГИ ============
function createRoad(x, z, w, h) {
  const roadGeo = new THREE.PlaneGeometry(w, h);
  const roadMat = new THREE.MeshStandardMaterial({ color: 0x444444, roughness: 0.9 });
  const road = new THREE.Mesh(roadGeo, roadMat);
  road.rotation.x = -Math.PI / 2;
  road.position.set(x, 0.01, z);
  road.receiveShadow = true;
  scene.add(road);
  
  // Разметка
  if (h > 8) {
    for (let i = -h/2 + 2; i < h/2; i += 3) {
      const lineGeo = new THREE.PlaneGeometry(0.15, 1.5);
      const lineMat = new THREE.MeshStandardMaterial({ color: 0xffffff });
      const line = new THREE.Mesh(lineGeo, lineMat);
      line.rotation.x = -Math.PI / 2;
      line.position.set(x, 0.02, z + i);
      scene.add(line);
    }
  }
}

// Главные дороги
createRoad(0, 0, 8, 60);   // Вертикальная главная
createRoad(0, 0, 40, 8);   // Горизонтальная главная
createRoad(-15, 0, 6, 60);
createRoad(15, 0, 6, 60);
createRoad(0, -25, 40, 6);
createRoad(0, 25, 40, 6);

// Тротуары
function createSidewalk(x, z, w, h) {
  const geo = new THREE.PlaneGeometry(w, h);
  const mat = new THREE.MeshStandardMaterial({ color: 0x999999, roughness: 0.7 });
  const sw = new THREE.Mesh(geo, mat);
  sw.rotation.x = -Math.PI / 2;
  sw.position.set(x, 0.08, z);
  sw.receiveShadow = true;
  scene.add(sw);
}

createSidewalk(0, 6.5, 10, 0.8);
createSidewalk(0, -6.5, 10, 0.8);
createSidewalk(6.5, 0, 0.8, 60);
createSidewalk(-6.5, 0, 0.8, 60);

// ============ ЗДАНИЯ ============
function createBuilding(x, z, w, h, d, color, name, type = 'building') {
  const group = new THREE.Group();
  
  const buildingGeo = new THREE.BoxGeometry(w, h, d);
  const buildingMat = new THREE.MeshStandardMaterial({ color, roughness: 0.5 });
  const building = new THREE.Mesh(buildingGeo, buildingMat);
  building.position.y = h/2;
  building.castShadow = true;
  building.receiveShadow = true;
  group.add(building);
  
  // Окна
  const windowGeo = new THREE.PlaneGeometry(0.6, 0.8);
  const windowMat = new THREE.MeshStandardMaterial({ color: 0x88ccff, emissive: 0x222244, emissiveIntensity: 0.3 });
  
  for (let floor = 0; floor < Math.floor(h/3); floor++) {
    for (let wx = -w/3; wx <= w/3; wx += w/3) {
      const window1 = new THREE.Mesh(windowGeo, windowMat);
      window1.position.set(wx, 1.5 + floor * 3, d/2 + 0.01);
      group.add(window1);
      
      const window2 = new THREE.Mesh(windowGeo, windowMat);
      window2.position.set(wx, 1.5 + floor * 3, -d/2 - 0.01);
      window2.rotation.y = Math.PI;
      group.add(window2);
    }
  }
  
  group.position.set(x, 0, z);
  group.userData = { name, type, buildingType: type };
  
  // Метка
  const labelDiv = document.createElement('div');
  labelDiv.textContent = name;
  labelDiv.style.color = '#FFD700';
  labelDiv.style.fontSize = '12px';
  labelDiv.style.fontWeight = 'bold';
  labelDiv.style.textShadow = '1px 1px 2px black';
  const label = new CSS2DObject(labelDiv);
  label.position.set(0, h + 2, 0);
  group.add(label);
  
  return group;
}

// Жилые дома
const buildings = [];
buildings.push(createBuilding(-20, -20, 6, 15, 5, 0xcc9966, '🏠 ЖК "Солнечный"', 'house'));
buildings.push(createBuilding(-25, 20, 5, 18, 5, 0xddbb88, '🏢 ЖК "Центральный"', 'apartment'));
buildings.push(createBuilding(20, -20, 7, 12, 6, 0xbbaa88, '🏘️ Дом №42', 'house'));
buildings.push(createBuilding(25, 20, 5, 20, 5, 0xccbb99, '🌆 Элитный ЖК', 'apartment'));
buildings.push(createBuilding(10, -20, 5, 10, 5, 0xddaa77, '🏠 Коттедж', 'house'));
buildings.push(createBuilding(-10, 22, 6, 14, 5, 0xcc9977, '🏢 ЖК "Северный"', 'apartment'));

// Магазины
buildings.push(createBuilding(-18, -10, 8, 6, 6, 0x44aa44, '🏪 Продуктовый 24/7', 'shop'));
buildings.push(createBuilding(18, -10, 10, 5, 8, 0x4444cc, '🚗 Автосалон "АвтоМир"', 'car-shop'));
buildings.push(createBuilding(0, 20, 8, 5, 7, 0xcc4444, '🔧 СТО "Мастер"', 'repair'));
buildings.push(createBuilding(20, 10, 6, 6, 6, 0xccaa44, '👔 Магазин одежды', 'clothes-shop'));
buildings.push(createBuilding(-20, 10, 7, 5, 6, 0x44cccc, '🏦 Банк', 'bank'));

// Гаражи
buildings.push(createBuilding(-15, -15, 4, 3, 4, 0x777777, '🔒 Гараж #1', 'garage'));
buildings.push(createBuilding(15, -15, 4, 3, 4, 0x777777, '🔒 Гараж #2', 'garage'));
buildings.push(createBuilding(-15, 15, 4, 3, 4, 0x777777, '🔒 Гараж #3', 'garage'));
buildings.push(createBuilding(15, 15, 4, 3, 4, 0x777777, '🔒 Гараж #4', 'garage'));

buildings.forEach(b => scene.add(b));

// ============ ДЕРЕВЬЯ И ДЕКОР ============
function createTree(x, z) {
  const group = new THREE.Group();
  const trunkGeo = new THREE.CylinderGeometry(0.15, 0.2, 2.5, 8);
  const trunkMat = new THREE.MeshStandardMaterial({ color: 0x8B4513 });
  const trunk = new THREE.Mesh(trunkGeo, trunkMat);
  trunk.position.y = 1.25;
  trunk.castShadow = true;
  group.add(trunk);
  
  const leavesGeo = new THREE.SphereGeometry(1.2, 8, 6);
  const leavesMat = new THREE.MeshStandardMaterial({ color: 0x228B22 });
  const leaves = new THREE.Mesh(leavesGeo, leavesMat);
  leaves.position.y = 2.8;
  leaves.castShadow = true;
  group.add(leaves);
  
  group.position.set(x, 0, z);
  scene.add(group);
}

for (let i = -28; i <= 28; i += 7) {
  createTree(i, -28);
  createTree(i, 28);
  createTree(-28, i);
  createTree(28, i);
}

// Парковочные места (разметка)
function createParkingSpot(x, z) {
  const geo = new THREE.PlaneGeometry(2.2, 4.5);
  const mat = new THREE.MeshStandardMaterial({ color: 0x555555 });
  const spot = new THREE.Mesh(geo, mat);
  spot.rotation.x = -Math.PI / 2;
  spot.position.set(x, 0.02, z);
  scene.add(spot);
  
  // Линии
  const lineGeo = new THREE.BoxGeometry(0.05, 0.01, 4.5);
  const lineMat = new THREE.MeshStandardMaterial({ color: 0xffffff });
  [-1.1, 1.1].forEach(offset => {
    const line = new THREE.Mesh(lineGeo, lineMat);
    line.position.set(x + offset, 0.03, z);
    scene.add(line);
  });
}

for (let i = -8; i <= 10; i += 3) {
  createParkingSpot(i, 12);
}

// ============ УПРАВЛЕНИЕ ============
const keys = {};
window.addEventListener('keydown', (e) => { keys[e.key.toLowerCase()] = true; });
window.addEventListener('keyup', (e) => { keys[e.key.toLowerCase()] = false; });

// ============ ФУНКЦИИ ============
function updateUI() {
  document.getElementById('money').textContent = money.toLocaleString() + ' ₽';
  document.getElementById('inv-list').textContent = inventory.length > 0 ? inventory.join(', ') : 'Пусто';
  document.getElementById('car-name').textContent = isInCar && currentCar ? 
    '🚗 ' + currentCar.userData.model.name : '🚶 Пешком';
}

function openShop(type) {
  const panel = document.getElementById('shop-panel');
  const title = document.getElementById('shop-title');
  const content = document.getElementById('shop-content');
  
  panel.style.display = 'block';
  content.innerHTML = '';
  
  if (type === 'car-shop') {
    title.textContent = '🚗 Автосалон "АвтоМир"';
    carModels.forEach(car => {
      const btn = document.createElement('button');
      btn.className = 'shop-btn';
      btn.textContent = `${car.name} - ${car.price.toLocaleString()} ₽`;
      btn.onclick = () => buyCar(car);
      content.appendChild(btn);
    });
  } else if (type === 'shop') {
    title.textContent = '🏪 Продуктовый магазин';
    const items = [
      { name: 'Хлеб', price: 50 },
      { name: 'Вода', price: 35 },
      { name: 'Кола', price: 80 },
      { name: 'Чипсы', price: 120 }
    ];
    items.forEach(item => {
      const btn = document.createElement('button');
      btn.className = 'shop-btn';
      btn.textContent = `${item.name} - ${item.price} ₽`;
      btn.onclick = () => buyItem(item);
      content.appendChild(btn);
    });
  } else if (type === 'clothes-shop') {
    title.textContent = '👔 Магазин одежды';
    const items = [
      { name: 'Куртка', price: 2500 },
      { name: 'Джинсы', price: 1800 },
      { name: 'Кепка', price: 900 }
    ];
    items.forEach(item => {
      const btn = document.createElement('button');
      btn.className = 'shop-btn';
      btn.textContent = `${item.name} - ${item.price} ₽`;
      btn.onclick = () => buyItem(item);
      content.appendChild(btn);
    });
  }
}

function closeShop() {
  document.getElementById('shop-panel').style.display = 'none';
}

function buyCar(model) {
  if (money >= model.price) {
    money -= model.price;
    inventory.push(model.name + ' (ключи)');
    updateUI();
    alert(`Вы купили ${model.name}! Ключи в инвентаре. Подойдите к машине и нажмите E.`);
    closeShop();
  } else {
    alert('Недостаточно денег!');
  }
}

function buyItem(item) {
  if (money >= item.price) {
    money -= item.price;
    inventory.push(item.name);
    updateUI();
    alert(`Вы купили ${item.name}!`);
  } else {
    alert('Недостаточно денег!');
  }
}

function enterCar(car) {
  currentCar = car;
  isInCar = true;
  carSpeed = 0;
  player.visible = false;
  document.getElementById('hint').textContent = '🚗 WASD - газ/тормоз/поворот | Пробел - ручник | Q - выйти';
}

function exitCar() {
  if (!isInCar || !currentCar) return;
  isInCar = false;
  player.position.copy(currentCar.position);
  player.position.x += 2;
  player.visible = true;
  carSpeed = 0;
  document.getElementById('hint').textContent = '🎮 WASD - движение | E - войти в машину | F - взаимодействие';
}

// Глобальные функции для HTML
window.openShop = openShop;
window.closeShop = closeShop;
window.buyCar = buyCar;
window.buyItem = buyItem;

// ============ ИГРОВОЙ ЦИКЛ ============
function animate() {
  requestAnimationFrame(animate);
  
  // Поворот игрока/машины
  let rotationSpeed = 0.03;
  
  if (isInCar && currentCar) {
    // Управление машиной
    if (keys['w'] || keys['arrowup']) carSpeed = Math.min(carSpeed + carAcceleration, maxCarSpeed);
    if (keys['s'] || keys['arrowdown']) carSpeed = Math.max(carSpeed - carAcceleration, -maxCarSpeed/2);
    
    // Торможение
    if (!keys['w'] && !keys['arrowup'] && !keys['s'] && !keys['arrowdown']) {
      if (carSpeed > 0) carSpeed = Math.max(0, carSpeed - carFriction);
      if (carSpeed < 0) carSpeed = Math.min(0, carSpeed + carFriction);
    }
    
    // Ручник
    if (keys[' ']) {
      carSpeed *= 0.85;
      handbrake = true;
    } else {
      handbrake = false;
    }
    
    // Поворот
    if (keys['a'] || keys['arrowleft']) currentCar.rotation.y += rotationSpeed;
    if (keys['d'] || keys['arrowright']) currentCar.rotation.y -= rotationSpeed;
    
    // Движение
    currentCar.position.x += Math.sin(currentCar.rotation.y) * carSpeed;
    currentCar.position.z += Math.cos(currentCar.rotation.y) * carSpeed;
    
    // Камера за машиной
    const camOffset = new THREE.Vector3(0, 5, -8);
    camOffset.applyAxisAngle(new THREE.Vector3(0, 1, 0), currentCar.rotation.y);
    camera.position.lerp(
      new THREE.Vector3(
        currentCar.position.x + camOffset.x,
        currentCar.position.y + camOffset.y,
        currentCar.position.z + camOffset.z
      ), 0.1
    );
    camera.lookAt(currentCar.position.x, currentCar.position.y + 1, currentCar.position.z);
    
    // Спидометр
    const speedKmh = Math.abs(Math.round(carSpeed * 100));
    document.getElementById('speedometer').textContent = speedKmh + ' км/ч';
  } else {
    // Управление пешком
    let moveX = 0, moveZ = 0;
    if (keys['w'] || keys['arrowup']) moveZ = -playerSpeed;
    if (keys['s'] || keys['arrowdown']) moveZ = playerSpeed;
    if (keys['a'] || keys['arrowleft']) moveX = -playerSpeed;
    if (keys['d'] || keys['arrowright']) moveX = playerSpeed;
    
    // Поворот игрока (клавиши Q/E для поворота)
    if (keys['q']) player.rotation.y += rotationSpeed * 1.5;
    if (keys['e'] && !isInCar) player.rotation.y -= rotationSpeed * 1.5;
    
    // Определяем направление относительно камеры
    const forward = new THREE.Vector3(0, 0, -1);
    forward.applyQuaternion(camera.quaternion);
    forward.y = 0;
    forward.normalize();
    
    const right = new THREE.Vector3(1, 0, 0);
    right.applyQuaternion(camera.quaternion);
    right.y = 0;
    right.normalize();
    
    if (moveX !== 0 || moveZ !== 0) {
      player.position.x += right.x * moveX + forward.x * moveZ;
      player.position.z += right.z * moveX + forward.z * moveZ;
      
      // Поворот игрока в направлении движения
      const angle = Math.atan2(right.x * moveX + forward.x * moveZ, right.z * moveX + forward.z * moveZ);
      player.rotation.y = angle;
    }
    
    // Камера от третьего лица
    const camPos = new THREE.Vector3(
      player.position.x + Math.sin(player.rotation.y) * 5,
      player.position.y + 4,
      player.position.z + Math.cos(player.rotation.y) * 5
    );
    camera.position.lerp(camPos, 0.1);
    camera.lookAt(player.position.x, player.position.y + 1.5, player.position.z);
    
    document.getElementById('speedometer').textContent = '0 км/ч';
    
    // Проверка входа в машину (E)
    if (keys['e']) {
      keys['e'] = false;
      let closestCar = null;
      let minDist = 4;
      
      cars.forEach(car => {
        const dist = player.position.distanceTo(car.position);
        if (dist < minDist) {
          minDist = dist;
          closestCar = car;
        }
      });
      
      if (closestCar) {
        enterCar(closestCar);
      }
    }
    
    // Взаимодействие (F)
    if (keys['f']) {
      keys['f'] = false;
      buildings.forEach(building => {
        const dist = player.position.distanceTo(building.position);
        if (dist < 8) {
          if (building.userData.type === 'shop' || building.userData.type === 'car-shop' || building.userData.type === 'clothes-shop') {
            openShop(building.userData.type);
          } else if (building.userData.type === 'bank') {
            const bonus = Math.floor(Math.random() * 5000) + 1000;
            money += bonus;
            updateUI();
            alert(`💳 Банк: на ваш счёт зачислено ${bonus} ₽`);
          } else {
            alert(`${building.userData.name}: доступно для входа`);
          }
        }
      });
    }
  }
  
  // Выход из машины (Q в машине)
  if (isInCar && keys['q']) {
    keys['q'] = false;
    exitCar();
  }
  
  renderer.render(scene, camera);
  labelRenderer.render(scene, camera);
  updateUI();
}

// ============ ЗАПУСК ============
animate();

// Обработка ресайза
window.addEventListener('resize', () => {
  camera.aspect = window.innerWidth / window.innerHeight;
  camera.updateProjectionMatrix();
  renderer.setSize(window.innerWidth, window.innerHeight);
  labelRenderer.setSize(window.innerWidth, window.innerHeight);
});

console.log('🎮 Russian RP Sandbox запущен!');
console.log('🏠 Карта: жилые дома, магазины, гаражи, автосалон');
console.log('🚗 8 машин доступно для покупки');
console.log('💡 E - сесть в машину, Q - выйти, F - взаимодействие');
</script>
